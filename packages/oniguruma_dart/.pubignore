# Files kept in the git repo but excluded from the published pub.dev package.
# pub uses .pubignore (falling back to .gitignore) to decide what to publish.

# Build artifacts / editor / OS cruft.
.dart_tool/
.idea/
.vscode/
.DS_Store

# The vendored Oniguruma C library: differential/fuzz oracle and benchmark
# reference only, not part of the Dart package (~12 MB of C sources).
oniguruma-master/

# Dev-only tooling & docs, kept in the repo, not shipped to consumers:
#   * benchmark/  harnesses, reports, corpora, and the C reference CLI; they
#     can't run without the excluded corpora + C library anyway. The headline
#     results live in benchmarks.md at this package's root (which IS published).
#   * tool/       code generators for the Unicode data tables.
#   * docs/       deep-dive investigation notes.
benchmark/
tool/
docs/

# Differential / fuzz harnesses require the C reference above, so they can't
# run from the published package.
test/differential/
test/oracle/
