# Files excluded from the published pub.dev package.
#
# This file is authoritative for publishing and does not rely on git state, so
# it also lists the build/editor artifacts (normally handled by .gitignore) to
# keep the archive correct even when publishing from a fresh checkout.
#
# What DOES ship: lib/, bin/setup.dart, hook/build.dart, src/oniguruma_shim.c,
# src/config/, prebuilt/** (minus the raw web wasm), pubspec.yaml, README.md. The
# prebuilt libraries are the whole point of the package; make sure nothing below
# matches them.

# Build artifacts and caches.
build/
.dart_tool/
coverage/
doc/api/
**/doc/api/

# Editor / tooling metadata.
*.iml
.idea/
.vscode/
.DS_Store
.flutter-plugins-dependencies

# Lockfile is not published for libraries.
pubspec.lock

# Tests: consumers don't run the package's tests.
test/

# Dev-only: replay/benchmark harness and the web smoke script.
benchmark/
tool/

# Dev-only: the mainstream benchmark harness (built via `dart build cli` and
# driven by ../oniguruma_dart/benchmark/ffi_bench.py); not a package executable.
# NOTE: bin/setup.dart MUST ship (it is the `dart run oniguruma_native:setup`
# command consumers run to fetch the web wasm), so exclude only the benchmark.
bin/mainstream_bench.dart

# `dart build cli` output bundle.
build/

# CI infrastructure that produces prebuilt/ (kept in git, built by GitHub
# Actions), not needed by consumers. Note: tool/ above already covers
# tool/prebuilt/; listed explicitly for clarity.
tool/prebuilt/

# The web wasm blob is delivered to consumers as a GitHub Release asset (fetched
# by `dart run oniguruma_native:setup`, or at runtime by loadWasm's fallback), not
# shipped in the pub archive. Keep it in git for provenance and so the release
# workflow can upload it; exclude it from the published package.
prebuilt/web/

# The Oniguruma C sources are never vendored; the build hook downloads them
# on demand. This scratch path won't exist in a clean checkout, but exclude it
# defensively so a local extraction can never leak into the archive.
src/oniguruma/
