# Files excluded from the published pub.dev package (but kept in the git repo).
# pub uses .pubignore instead of .gitignore when deciding what to publish, so
# this file also re-lists the build artifacts that .gitignore already excludes.

# Build artifacts / tooling output.
.dart_tool/
.idea/
.vscode/
.DS_Store

# The vendored Oniguruma C library — differential/fuzz oracle and benchmark
# reference only, not part of the Dart package (~12 MB of C sources).
oniguruma-master/

# Compiled benchmark binaries — never ship build artifacts.
benchmark/bench_dart
benchmark/bench_vs_regexp
benchmark/c/onig_cli

# Web-benchmark build artifacts (compiled JS + embedded corpus, ~6 MB).
benchmark/web/bench_web.js
benchmark/web/bench_web.js.deps
benchmark/web/bench_web.js.map
benchmark/web/corpus_data.g.dart

# Large benchmark corpora (kept in the repo for reproducible benchmarks;
# excluded here to keep the package lean — results are in benchmark/REPORT.md).
benchmark/datasets/

# Differential/fuzz harnesses require the C reference above, so they can't run
# from the published package.
test/differential/
test/oracle/
