# Workspace-wide ignores. Package-specific ignores live in each package's own
# .gitignore (e.g. packages/oniguruma_dart/.gitignore).

# Dart & pub build artifacts (https://dart.dev/tools/private-files)
.dart_tool/
.packages
build/

# Shared workspace lockfile (this repo is a set of library packages).
pubspec.lock

# Editors / OS junk
.idea/
.vscode/
*.iml
.DS_Store
